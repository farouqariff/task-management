# Copy this file to .env and fill in the values before running docker compose up

MYSQL_ROOT_PASSWORD=devpassword
MYSQL_DATABASE=task_management

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt

# URL the browser uses to reach the backend
VITE_API_BASE_URL=http://localhost:5000

# Gmail SMTP — create a Gmail App Password at myaccount.google.com/apppasswords
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# Base URL for password reset links sent in emails
FRONTEND_URL=http://localhost
